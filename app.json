{
  "expo": {
    "name": "Kairos",
    "slug": "kairos",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "kairos",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kairos.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.kairos.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      "expo-web-browser"
    ]
  }
}
